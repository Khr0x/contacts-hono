# Node Environment
NODE_ENV=development

# Server Configuration
PORT=3000

# Database Configuration (Supabase)
# Para Supabase, usa el Connection String del dashboard en Database Settings
# Formato: postgresql://postgres:[YOUR-PASSWORD]@[PROJECT-REF].supabase.co:5432/postgres
# Para desarrollo local con Supabase CLI: postgresql://postgres:postgres@localhost:54322/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Better Auth Configuration
BETTER_AUTH_SECRET=your-secret-key-min-32-characters-long-replace-this-in-production
BETTER_AUTH_URL=http://localhost:3000

# CORS Configuration
ALLOWED_ORIGINS=*

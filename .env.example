# Node Environment
NODE_ENV=development

# Server Configuration
PORT=3000

# Database (para Docker Compose local: postgres://postgres:postgres@db:5432/contacts)
# Para Supabase CLI local: postgresql://postgres:postgres@localhost:54322/postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/contacts

# Better Auth Configuration
BETTER_AUTH_SECRET=your-secret-key-min-32-characters-long-replace-this-in-production
BETTER_AUTH_URL=http://localhost:3000

# CORS Configuration
ALLOWED_ORIGINS=*
